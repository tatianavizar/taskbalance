<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><%= t("chores.index.title") %></h1>
</div>

<% if @chores.empty? %>
  <p class="text-muted"><%= t("chores.index.empty") %></p>
<% else %>
  <% @chores.group_by(&:household).each do |household, chores| %>
    <h2 class="h5 mb-2"><%= household.name %></h2>
    <ul class="list-group mb-4">
      <% chores.each do |chore| %>
        <li class="list-group-item d-flex justify-content-between align-items-center">
          <div>
            <span class="<%= 'text-decoration-line-through text-muted' if chore.completed? %>">
              <%= chore.effective_name %>
            </span>
            <span class="badge ms-2 <%= chore.completed? ? 'bg-success' : 'bg-secondary' %>">
              <%= t("chores.index.status.#{chore.status}") %>
            </span>
            <% if chore.due_date %>
              <small class="text-muted ms-2"><%= chore.due_date.strftime("%b %d") %></small>
            <% end %>
          </div>
          <div class="d-flex gap-2">
            <%= link_to t("common.edit"), edit_chore_path(chore), class: "btn btn-sm btn-outline-secondary" %>
            <% unless chore.completed? %>
              <%= button_to t("chores.index.mark_completed"),
                    mark_as_completed_chore_path(chore),
                    method: :patch,
                    class: "btn btn-sm btn-outline-success" %>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>
  <% end %>
<% end %>
