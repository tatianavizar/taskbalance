<h1 class="mb-4">Inviter un membre</h1>

<p class="text-muted mb-3">Foyer : <strong><%= @household.name %></strong></p>

<%= simple_form_for [@household, @household_member] do |f| %>
  <%= f.error_notification %>

  <div class="mb-3">
    <%= f.input :email, label: "Adresse email du membre", placeholder: "prenom@exemple.com" %>
  </div>

  <%= f.submit "Ajouter au foyer", class: "btn btn-primary" %>
<% end %>

<div class="mt-3">
  <%= link_to "Annuler", household_path(@household) %>
</div>
