<div class="d-flex justify-content-between align-items-center mb-4">
  <h1><%= t("tasks.liking_session.title") %></h1>
  <span class="text-muted"><%= @household.name %></span>
</div>

<% if @tasks_by_category.empty? %>
  <p class="text-muted"><%= t("tasks.liking_session.empty") %></p>
<% else %>
  <%= form_with url: household_liking_session_path(@household), method: :patch, local: true do %>
    <% @tasks_by_category.each do |category, tasks| %>
      <div class="card mb-4">
        <div class="card-header fw-semibold">
          <%= t("tasks.categories.#{category}") %>
        </div>
        <ul class="list-group list-group-flush">
          <% tasks.each do |task| %>
            <% liked_task = @liked_by_task_id[task.id] %>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <span><%= task.name %></span>
              <div class="btn-group btn-group-sm" role="group">
                <input type="radio" class="btn-check" name="preferences[<%= task.id %>]"
                       id="like_<%= task.id %>" value="true" autocomplete="off"
                       <%= "checked" if liked_task&.liked == true %>>
                <label class="btn btn-outline-success" for="like_<%= task.id %>">&#10003;</label>

                <input type="radio" class="btn-check" name="preferences[<%= task.id %>]"
                       id="dislike_<%= task.id %>" value="false" autocomplete="off"
                       <%= "checked" if liked_task&.liked == false %>>
                <label class="btn btn-outline-danger" for="dislike_<%= task.id %>">&#10007;</label>
              </div>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= submit_tag t("tasks.liking_session.submit"), class: "btn btn-primary" %>
  <% end %>
<% end %>

<div class="mt-3">
  <%= link_to t("common.back"), household_path(@household) %>
</div>
