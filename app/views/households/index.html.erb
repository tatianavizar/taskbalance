<h1 class="mb-4"><%= t("households.index.title") %></h1>

<% if @households.empty? %>
  <p class="text-muted"><%= t("households.index.empty") %></p>
<% else %>
  <ul class="list-group mb-4">
    <% @households.each do |household| %>
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <%= link_to household.name, household_path(household) %>
        <span class="badge bg-secondary"><%= t("common.members_count", count: household.users.count) %></span>
      </li>
    <% end %>
  </ul>
<% end %>

<%= link_to t("households.index.new_link"), new_household_path, class: "btn btn-primary" %>
