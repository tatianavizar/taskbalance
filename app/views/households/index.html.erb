<h1 class="mb-4">Mes foyers</h1>

<% if @households.empty? %>
  <p class="text-muted">Vous n'appartenez à aucun foyer pour l'instant.</p>
<% else %>
  <ul class="list-group mb-4">
    <% @households.each do |household| %>
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <%= link_to household.name, household_path(household) %>
        <span class="badge bg-secondary"><%= household.users.count %> membre(s)</span>
      </li>
    <% end %>
  </ul>
<% end %>

<%= link_to "Créer un foyer", new_household_path, class: "btn btn-primary" %>
